<%# STEP 4 — show view: one book, full detail. %>
<%# @book is set by BooksController#show via before_action :set_book. %>

<div class="row">
  <div class="col-md-4">
    <% if @book.cover_url.present? %>
      <%= image_tag @book.cover_url, alt: @book.title, class: "img-fluid rounded shadow-sm" %>
    <% else %>
      <div class="bg-secondary-subtle rounded text-center py-5 text-muted">no cover</div>
    <% end %>
  </div>

  <div class="col-md-8">
    <h1><%= @book.title %></h1>
    <p class="text-muted lead mb-1"><%= @book.author %></p>
    <% if @book.published_year.present? %>
      <p class="text-muted small">Published <%= @book.published_year %></p>
    <% end %>

    <% if @book.description.present? %>
      <p class="mt-4"><%= simple_format @book.description %></p>
    <% end %>

    <div class="mt-4 d-flex gap-2">
      <%= link_to "Edit", edit_book_path(@book), class: "btn btn-outline-secondary" %>
      <%# button_to issues a real POST/DELETE — link_to with method: :delete needs JS. %>
      <%= button_to "Delete", @book, method: :delete,
            class: "btn btn-outline-danger",
            form: { data: { turbo_confirm: "Remove #{@book.title} from your library?" } } %>
      <%= link_to "Back to library", books_path, class: "btn btn-link ms-auto" %>
    </div>
  </div>
</div>
