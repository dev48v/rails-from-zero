<!--
  STEP 4 — Application layout.
  Every view is rendered inside this shell unless an action explicitly opts out.
  Keeping <head>, the navbar, and global flash here means individual views can
  focus on the page-specific markup.
-->
<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Book Library</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <!--
      Bootstrap via CDN. Using a CDN keeps the project zero-build: no Node, no
      yarn, no esbuild. For a production app you would normally bundle, but
      teaching projects benefit from "open the file and read it" simplicity.
    -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-body-tertiary">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
      <div class="container">
        <%= link_to "Book Library", root_path, class: "navbar-brand fw-bold" %>
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <%= link_to "My books", books_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Search", search_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Add manually", new_book_path, class: "nav-link" %>
          </li>
        </ul>
      </div>
    </nav>

    <main class="container pb-5">
      <!-- Step 8 will replace this with a richer flash partial. For now a plain alert is enough. -->
      <% flash.each do |type, msg| %>
        <div class="alert alert-<%= type == 'notice' ? 'success' : 'warning' %>"><%= msg %></div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
